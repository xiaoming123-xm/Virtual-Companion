{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ATRI Chat",
  "version": "1.0.1",
  "identifier": "com.atri.chat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:9900",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ATRI Chat",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/atri-backend"
    ],
    "resources": [
      "binaries/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false,
        "installerHooks": "nsis/custom_settings.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
